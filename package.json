{
  "name": "expense-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run build:frontend && wrangler deploy",
    "build:frontend": "cd frontend && npm run build",
    "db:migrate:local": "wrangler d1 execute expense-tracker-db --local --file=src/db/schema.sql",
    "db:migrate": "wrangler d1 execute expense-tracker-db --remote --file=src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/oauth-providers": "^0.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.101.0"
  }
}
